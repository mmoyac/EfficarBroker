# Plantilla del .env de PRODUCCIÓN.
# Copiar a /root/docker/efficar/.env en el VPS y completar los valores CAMBIAR_*.
# Este archivo (el .example) SÍ va al repo; el .env real NUNCA se commitea.

# Usuario de Docker Hub donde el CI publica las imágenes efficar-backend / efficar-frontend.
DOCKER_USERNAME=mmoyac

# --- Postgres (contenedor propio) ---
POSTGRES_USER=efficar
POSTGRES_PASSWORD=CAMBIAR_por_password_fuerte
POSTGRES_DB=efficarbroker

# El backend lee DATABASE_URL directamente; el host es el servicio `db`.
# Debe coincidir con POSTGRES_USER/PASSWORD/DB de arriba.
DATABASE_URL=postgresql+psycopg://efficar:CAMBIAR_por_password_fuerte@db:5432/efficarbroker

# --- JWT ---
JWT_SECRET=CAMBIAR_por_secreto_largo_y_aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS: dominios de los FRONTS de cada tenant, separados por coma ---
# La API vive en su propio subdominio (efficar-api.effi4tech.cl) y los fronts la
# consumen cross-origin, así que aquí hay que listar el dominio de CADA tenant.
# Al dar de alta un tenant nuevo, agrega su dominio a esta lista y reinicia el backend.
BACKEND_CORS_ORIGINS=https://efficar-vendemostuautomovil.effi4tech.cl

# --- Seed en el arranque ---
# true = siembra catálogos + tenant vendemostuautomovil + usuarios en cada arranque
# (idempotente). Ponlo en false para desactivarlo una vez poblada la base.
SEED_ON_START=true
SEED_DEFAULT_PASSWORD=CAMBIAR_password_inicial_de_usuarios

# Datos operacionales de DEMO (vehículos/actas de prueba + 2º tenant demo).
# En producción DÉJALO EN false: la base queda con catálogos + maestras + el
# tenant real y sus usuarios, sin captaciones ni tenant demo.
SEED_DEMO_DATA=false
