# ---- PostgreSQL ----
POSTGRES_USER=efficar
POSTGRES_PASSWORD=efficar_dev
POSTGRES_DB=efficarbroker
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Backend ----
# URL usada por el backend dentro de Docker (host = nombre del servicio 'db')
DATABASE_URL=postgresql+psycopg://efficar:efficar_dev@db:5432/efficarbroker
API_V1_PREFIX=/api/v1
PROJECT_NAME=EffiCarBroker

# JWT
JWT_SECRET=change-me-in-prod-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (orígenes del backoffice en dev)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Password de desarrollo para usuarios del seed
SEED_DEFAULT_PASSWORD=admin123
